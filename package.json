{
  "name": "soulchain",
  "version": "1.0.0",
  "description": "AI-Powered Digital Legacy Platform - Store your memories forever on 0G Network with encryption, AI companionship, and blockchain permanence",
  "main": "index.js",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:smoke": "vitest run src/test/smoke.test.jsx",
    "test:unit": "vitest run src/test/unit.test.jsx",
    "test:integration": "vitest run src/test/integration.test.jsx",
    "test:functional": "vitest run src/test/functional.test.jsx",
    "test:e2e": "vitest run src/test/e2e.test.jsx",
    "test:all": "vitest run --reporter=verbose",
    "lint": "eslint src --ext .js,.jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext .js,.jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,md}\"",
    "clean": "rm -rf dist node_modules/.vite",
    "deploy": "npm run build && echo 'Build complete. Deploy the dist folder.'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_USERNAME/soulchain.git"
  },
  "homepage": "https://github.com/YOUR_USERNAME/soulchain#readme",
  "bugs": {
    "url": "https://github.com/YOUR_USERNAME/soulchain/issues"
  },
  "keywords": [
    "0G",
    "0G Network",
    "blockchain",
    "AI",
    "digital legacy",
    "memory storage",
    "decentralized storage",
    "hackathon",
    "0G Arena",
    "NFT",
    "encryption",
    "personal data"
  ],
  "author": {
    "name": "SoulChain Team",
    "email": "team@soulchain.io",
    "url": "https://github.com/YOUR_USERNAME"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@0gfoundation/0g-storage-ts-sdk": "^1.0.0",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/postcss": "^4.3.1",
    "idb": "^8.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@ethersproject/providers": "^5.8.0",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@typechain/ethers-v6": "^0.4.0",
    "@typechain/hardhat": "^8.0.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.0",
    "chai": "^4.5.0",
    "ethers": "^6.13.1",
    "hardhat": "^2.17.0",
    "hardhat-gas-reporter": "^1.0.10",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.15",
    "solidity-coverage": "^0.8.17",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typechain": "^8.3.2",
    "typescript": "^6.0.3",
    "vite": "^4.4.0",
    "vitest": "^4.1.9"
  }
}
